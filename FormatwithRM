/** Fungsi: Tambah simbol RM ke nilai wang */
function formatWithRM() {
  var sheet = SpreadsheetApp.getActiveSheet();
  var range = sheet.getActiveRange();
  var values = range.getValues();
  var cleaned = values.map(row => row.map(cell => cell.toString().replace(/Rm|RM|rm/g, '')));
  range.setValues(cleaned).setNumberFormat('"RM"#,##0.00');
}
